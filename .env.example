# Copy this to .env.local for local development
# Add these as Environment Variables in your Vercel dashboard

# Your Gemini API key (used for paid/pro tier users)
GEMINI_API_KEY=your_gemini_api_key_here

# Secret access code you give to paid customers
# Choose anything — e.g. GOLD2024 or a random string
PAID_ACCESS_CODE=your_secret_access_code_here
